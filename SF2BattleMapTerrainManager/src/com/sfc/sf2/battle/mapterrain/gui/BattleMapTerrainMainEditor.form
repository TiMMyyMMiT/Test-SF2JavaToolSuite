                                <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton11">
                                  <Properties>
                                    <Property name="messageText" type="java.lang.String" value="&lt;html&gt;&quot;Land effect&quot; determines how each &lt;i&gt;movement type&lt;/i&gt; is affected by each &lt;i&gt;terrain type&lt;/i&gt;.&lt;br&gt;Each land effect entry determines defensive bonus and the movement cost that will affect the a unit with the specific movement type on the specific terrain.&lt;br&gt;&lt;br&gt;&lt;b&gt;Defenses:&lt;/b&gt;&lt;br&gt;Obstructed: Indicates that this &lt;i&gt;movement type&lt;/i&gt; cannot move onto this tile.&lt;br&gt;LE0: By default, provides 0% defensive bonus (no bonus).&lt;br&gt;LE15: By default, provides 15% defensive bonus.&lt;br&gt;LE30: By default, provides 30% defensive bonus.&lt;br&gt;&lt;br&gt;&lt;b&gt;Movement costs:&lt;/b&gt; Higher numbers = slower movement on that tile.&lt;/html&gt;"/>
                                    <Property name="text" type="java.lang.String" value=""/>
                                  </Properties>
                                </Component>
