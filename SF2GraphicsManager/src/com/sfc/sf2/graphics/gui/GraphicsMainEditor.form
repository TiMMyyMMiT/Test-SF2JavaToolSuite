                                            <Property name="messageText" type="java.lang.String" value="&lt;html&gt;The compression used for the graphic.&lt;br&gt;&lt;b&gt;- None:&lt;/b&gt; Uncompressed graphics. Usually for small images (e.g. icons).&lt;br&gt;&lt;b&gt;- Basic:&lt;/b&gt; Simple compression. Used in map sprites and tilesets.&lt;br&gt;&lt;b&gt;- Stack:&lt;/b&gt; Complex compression. Used for all larger images (e.g. portraits, spell/invocations, and all battle graphics).&lt;/html&gt;"/>
                                            <Property name="text" type="java.lang.String" value=""/>
                                          </Properties>
                                        </Component>
