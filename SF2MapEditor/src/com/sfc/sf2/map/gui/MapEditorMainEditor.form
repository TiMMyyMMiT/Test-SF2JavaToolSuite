                            <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableAreas">
                              <Properties>
                                <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                  <Border info="null"/>
                                </Property>
                                <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Areas:&lt;/b&gt; Indicates areas for bounding the camera (forcing it to stay within the region), defining upper (roof) layers, and for foreground/background effects.&lt;br&gt;- L1 X/Y/X&apos;/Y&apos;: Defines a rectangle representing the area. The game camera is bound to this space.&lt;br&gt;- L2 F X/Y: Defines the foreground (upper) layer for the area. Used to define roofs, treetops, etc.&lt;br&gt;- L2 B X/Y: Defines the backgroun layer. TODO: What is it used for.&lt;br&gt;- L1/L2 P X/Y: Defines the parallax effect of the layer 1 or 2. Parallax causes layers to scroll at different speeds as the player character moves.&lt;br&gt;- L1/2 S X/Y: Defines the autoscroll speed for layers 1 &amp; 2. Autoscroll will cause the layer to constantly scroll.&lt;br&gt;- Music: The music to start playing when the player character enters the area.&lt;br&gt;&lt;br&gt;&lt;b&gt;When Area row is selected:&lt;/b&gt;Left-click to drag the closest corner or point of the area (look for the circular blue handle).&lt;/html&gt;"/>
                                <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                  <ComponentRef name="mapAreaTableModel"/>
                                </Property>
                                <Property name="selectionMode" type="int" value="0"/>
                                <Property name="singleClickText" type="boolean" value="true"/>
                                <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                  <Dimension value="[150, 150]"/>
                                </Property>
                                <Property name="preferredSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                  <Dimension value="[260, 150]"/>
                                </Property>
                              </Properties>
                              <Constraints>
                                <Constraint layoutClass="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout" value="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout$JTabbedPaneConstraintsDescription">
                                  <JTabbedPaneConstraints tabName="Areas">
                                    <Property name="tabTitle" type="java.lang.String" value="Areas"/>
                                  </JTabbedPaneConstraints>
                                </Constraint>
                              </Constraints>
                            </Component>
