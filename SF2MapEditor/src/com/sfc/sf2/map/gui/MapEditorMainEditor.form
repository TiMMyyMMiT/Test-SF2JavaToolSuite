                                  <SubComponents>
                                    <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableFlagCopies">
                                      <Properties>
                                        <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                          <Border info="null"/>
                                        </Property>
                                        <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Flag copies event:&lt;/b&gt; If a game flag is triggered when the map loads, then copies map blocks in one section of the map to another section.&lt;br&gt;- Flag: The game flag to trigger the event.&lt;br&gt;- Flag Info: A helpful description of what the flag value refers to.&lt;br&gt;- Source X/Y/X&apos;/Y&apos;: Defines a rectangle to copy blocks FROM.&lt;br&gt;- Dest. X/Y: The top-left of the section to copy blocks TO. Uses the same width and height as the source.&lt;br&gt;- Comment: Optional comment that is saved to the .asm file.&lt;br&gt;&lt;br&gt;&lt;b&gt;When Flag Copy row is selected:&lt;/b&gt;TODO.&lt;/html&gt;"/>
                                        <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                          <ComponentRef name="mapFlagCopyTableModel"/>
                                        </Property>
                                        <Property name="selectionMode" type="int" value="0"/>
                                        <Property name="singleClickText" type="boolean" value="true"/>
                                        <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                        <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                          <Dimension value="null"/>
                                        </Property>
                                      </Properties>
                                      <Constraints>
                                        <Constraint layoutClass="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout" value="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout$JTabbedPaneConstraintsDescription">
                                          <JTabbedPaneConstraints tabName="Flag Copies">
                                            <Property name="tabTitle" type="java.lang.String" value="Flag Copies"/>
                                          </JTabbedPaneConstraints>
                                        </Constraint>
                                      </Constraints>
                                    </Component>
                                    <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableStepCopies">
                                      <Properties>
                                        <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                          <Border info="null"/>
                                        </Property>
                                        <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Step copies event:&lt;/b&gt; If the player character steps on this map block, then copies map blocks in one section of the map to another section.&lt;br&gt;- Trigger X/Y: The trigger position for the step copy.&lt;br&gt;- Source X/Y/X&apos;/Y&apos;: Defines a rectangle to copy blocks FROM.&lt;br&gt;- Dest. X/Y: The top-left of the section to copy blocks TO. Uses the width and height from Source.&lt;br&gt;- Comment: Optional comment that is saved to the .asm file.&lt;br&gt;&lt;br&gt;NOTE: Step copy triggers before the character enters the Trigger X/Y block. If the Destination X/Y is the same block as the Trigger X/Y, this can then trigger another flag/event from the copied source (e.g. see door Hide flags in most town maps).&lt;br&gt;&lt;br&gt;&lt;b&gt;When Flag Copy row is selected:&lt;/b&gt;TODO.&lt;/html&gt;"/>
                                        <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                          <ComponentRef name="mapStepCopyTableModel"/>
                                        </Property>
                                        <Property name="selectionMode" type="int" value="0"/>
                                        <Property name="singleClickText" type="boolean" value="true"/>
                                        <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                        <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                          <Dimension value="null"/>
                                        </Property>
                                      </Properties>
                                      <Constraints>
                                        <Constraint layoutClass="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout" value="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout$JTabbedPaneConstraintsDescription">
                                          <JTabbedPaneConstraints tabName="Step Copies">
                                            <Property name="tabTitle" type="java.lang.String" value="Step Copies"/>
                                          </JTabbedPaneConstraints>
                                        </Constraint>
                                      </Constraints>
                                    </Component>
                                    <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableRoofCopies">
                                      <Properties>
                                        <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                          <Border info="null"/>
                                        </Property>
                                        <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Roof copy event:&lt;/b&gt; If the player character enters the trigger block, then copies map blocks in one section of the upper layer to another section of the upper layer.&lt;br&gt;- Trigger X/Y: The trigger position for the step copy.&lt;br&gt;- Source X/Y/X&apos;/Y&apos;: Defines a rectangle to copy blocks FROM. Set Source X/Y both to 255 to automatically detect the source position from the destination, in relation to the 1st area defined.&lt;br&gt;- Dest. X/Y: The top-left of the section to copy blocks TO. Uses the width and height from the Source.&lt;br&gt;- Comment: Optional comment that is saved to the .asm file.&lt;br&gt;&lt;br&gt;NOTE: Use Show flags to reverse the previous Roof Copy (i.e. to make the roof appear again).&lt;br&gt;&lt;br&gt;&lt;b&gt;When Flag Copy row is selected:&lt;/b&gt;TODO.&lt;/html&gt;"/>
                                        <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                          <ComponentRef name="mapRoofCopyTableModel"/>
                                        </Property>
                                        <Property name="selectionMode" type="int" value="0"/>
                                        <Property name="singleClickText" type="boolean" value="true"/>
                                        <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                        <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                          <Dimension value="null"/>
                                        </Property>
                                      </Properties>
                                      <Constraints>
                                        <Constraint layoutClass="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout" value="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout$JTabbedPaneConstraintsDescription">
                                          <JTabbedPaneConstraints tabName="Roof Copies">
                                            <Property name="tabTitle" type="java.lang.String" value="Roof Copies"/>
                                          </JTabbedPaneConstraints>
                                        </Constraint>
                                      </Constraints>
                                    </Component>
                                  </SubComponents>
                                </Container>
                              </SubComponents>
                            </Container>
                            <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableWarps">
                              <Properties>
                                <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                  <Border info="null"/>
                                </Property>
                                <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Warp event:&lt;/b&gt; Teleports the player to a new position or a new map.&lt;br&gt;- Trigger X/Y: The trigger point for the warp.&lt;br&gt;- Scroll Dir: The direction that the camera scrolls when warping (used for overworld maps).&lt;br&gt; - Dest. Map: The map to warp to. Set to &quot;CURRENT&quot; to warp to a different position on the current map.&lt;br&gt;- Dest X/Y: The destination position to warp to (on this map or another.&lt;br&gt;- Facing: The direction to face at the warp destination.&lt;br&gt;- Comment: Optional comment that is saved to the .asm file.&lt;br&gt;&lt;br&gt;&lt;b&gt;When a warp row is selected:&lt;/b&gt; Left click and drag will set the set the Trigger or Destination X/Y position of the selected item event, whichever is closer to the cursor.&lt;/html&gt;"/>
                                <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                  <ComponentRef name="mapWarpTableModel"/>
                                </Property>
                                <Property name="selectionMode" type="int" value="0"/>
                                <Property name="singleClickText" type="boolean" value="true"/>
                                <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                  <Dimension value="[260, 150]"/>
                                </Property>
                              </Properties>
                              <Constraints>
                                <Constraint layoutClass="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout" value="org.netbeans.modules.form.compat2.layouts.support.JTabbedPaneSupportLayout$JTabbedPaneConstraintsDescription">
                                  <JTabbedPaneConstraints tabName="Warps">
                                    <Property name="tabTitle" type="java.lang.String" value="Warps"/>
                                  </JTabbedPaneConstraints>
                                </Constraint>
                              </Constraints>
                            </Component>
