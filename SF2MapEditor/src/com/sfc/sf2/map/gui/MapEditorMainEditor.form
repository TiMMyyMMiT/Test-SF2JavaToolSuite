                                          <SubComponents>
                                            <Component class="javax.swing.JRadioButton" name="jRadioButtonWarp">
                                              <Properties>
                                                <Property name="buttonGroup" type="javax.swing.ButtonGroup" editor="org.netbeans.modules.form.RADComponent$ButtonGroupPropertyEditor">
                                                  <ComponentRef name="buttonGroupMapActions"/>
                                                </Property>
                                                <Property name="text" type="java.lang.String" value="Warp"/>
                                                <Property name="actionCommand" type="java.lang.String" value="0x1000"/>
                                                <Property name="name" type="java.lang.String" value="Warp Flag Toggle" noResource="true"/>
                                              </Properties>
                                              <Events>
                                                <EventHandler event="itemStateChanged" listener="java.awt.event.ItemListener" parameters="java.awt.event.ItemEvent" handler="jRadioButtonWarpsItemStateChanged"/>
                                              </Events>
                                            </Component>
                                            <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton5">
                                              <Properties>
                                                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Warp flag:&lt;/b&gt; Marks a block with a warp trigger. Must be used in conjunction with a Warp Event..&lt;br&gt;- Left click to flag a block with a warp&lt;br&gt;- Middle click to clear all flags from the block&lt;br&gt;- Right click to remove the warp flag&lt;/html&gt;"/>
                                                <Property name="text" type="java.lang.String" value=""/>
                                              </Properties>
                                            </Component>
                                            <Component class="javax.swing.JRadioButton" name="jRadioButtonTrigger">
                                              <Properties>
                                                <Property name="buttonGroup" type="javax.swing.ButtonGroup" editor="org.netbeans.modules.form.RADComponent$ButtonGroupPropertyEditor">
                                                  <ComponentRef name="buttonGroupMapActions"/>
                                                </Property>
                                                <Property name="text" type="java.lang.String" value="Trigger"/>
                                                <Property name="actionCommand" type="java.lang.String" value="0x1400"/>
                                                <Property name="name" type="java.lang.String" value="Trigger Flag Toggle" noResource="true"/>
                                              </Properties>
                                              <Events>
                                                <EventHandler event="itemStateChanged" listener="java.awt.event.ItemListener" parameters="java.awt.event.ItemEvent" handler="jRadioButtonTriggersItemStateChanged"/>
                                              </Events>
                                            </Component>
                                            <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton6">
                                              <Properties>
                                                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Trigger flag:&lt;/b&gt; Marks a block so that it will trigger a search for Copy Events.&lt;br&gt;- Left click to flag a block with a trigger&lt;br&gt;- Middle click to clear all flags from the block&lt;br&gt;- Right click to remove the trigger  flag&lt;/html&gt;"/>
                                                <Property name="text" type="java.lang.String" value=""/>
                                              </Properties>
                                            </Component>
                                            <Component class="javax.swing.JRadioButton" name="jRadioButtonLayerUp">
                                              <Properties>
                                                <Property name="buttonGroup" type="javax.swing.ButtonGroup" editor="org.netbeans.modules.form.RADComponent$ButtonGroupPropertyEditor">
                                                  <ComponentRef name="buttonGroupMapActions"/>
                                                </Property>
                                                <Property name="text" type="java.lang.String" value="Layer Up"/>
                                                <Property name="actionCommand" type="java.lang.String" value="0x2000"/>
                                                <Property name="name" type="java.lang.String" value="Layer Up Flag Toggle" noResource="true"/>
                                              </Properties>
                                              <Events>
                                                <EventHandler event="itemStateChanged" listener="java.awt.event.ItemListener" parameters="java.awt.event.ItemEvent" handler="jRadioButtonTriggersItemStateChanged"/>
                                              </Events>
                                            </Component>
                                            <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton16">
                                              <Properties>
                                                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Layer Up flag:&lt;/b&gt; Marks the block to shift the player (and followers) to the upper layer (the priority layer). Affected characters will be drawn above all map tiles.&lt;br&gt;- Left click to flag a block as a layer up block&lt;br&gt;- Middle click to clear all flags from the block&lt;br&gt;- Right click to remove the layer up flag&lt;br&gt;&lt;br&gt;NOTE: When the player character is in the upper layer, flag checks will occur as if the character was in the upper region of the area (see map_06 as reference).&lt;/html&gt;"/>
                                                <Property name="text" type="java.lang.String" value=""/>
                                              </Properties>
                                            </Component>
                                            <Component class="javax.swing.JRadioButton" name="jRadioButtonHideRoof">
                                              <Properties>
                                                <Property name="buttonGroup" type="javax.swing.ButtonGroup" editor="org.netbeans.modules.form.RADComponent$ButtonGroupPropertyEditor">
                                                  <ComponentRef name="buttonGroupMapActions"/>
                                                </Property>
                                                <Property name="text" type="java.lang.String" value="Hide (Roof)"/>
                                                <Property name="actionCommand" type="java.lang.String" value="0x0800"/>
                                                <Property name="name" type="java.lang.String" value="Hide (Roof) Flag Toggle" noResource="true"/>
                                              </Properties>
                                              <Events>
                                                <EventHandler event="itemStateChanged" listener="java.awt.event.ItemListener" parameters="java.awt.event.ItemEvent" handler="jRadioButtonRoofCopiesItemStateChanged"/>
                                              </Events>
                                            </Component>
                                            <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton21">
                                              <Properties>
                                                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Hide (Roof) flag:&lt;/b&gt; Marks the block to hide the upper layer (the priority layer). Used alongside Roof Copy events.&lt;br&gt;- Left click to flag a block as a hide block&lt;br&gt;- Middle click to clear all flags from the block&lt;br&gt;- Right click to remove the hide flag.&lt;br&gt;&lt;br&gt;NOTE: Many maps do not put the Hide flag on the door of a building but on the open doorway block that replaces the door (via Step Copy event).&lt;/html&gt;"/>
                                                <Property name="text" type="java.lang.String" value=""/>
                                              </Properties>
                                            </Component>
                                            <Component class="javax.swing.JRadioButton" name="jRadioButtonShowRoof">
                                              <Properties>
