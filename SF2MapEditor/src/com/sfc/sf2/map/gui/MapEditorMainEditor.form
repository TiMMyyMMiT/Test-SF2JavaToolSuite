                                <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton2">
                                  <Properties>
                                    <Property name="messageText" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Image Format:&lt;/b&gt; Select an image File (e.g. PNG or GIF).&lt;br&gt;Color format should be 4BPP / 16 indexed colors.&lt;br&gt;(Images of 8BPP / 256 indexed colors will be converted to 4 BPP / 16).&lt;br&gt;&lt;br&gt;&lt;b&gt;Flags:&lt;/b&gt; Outputs a representation of the map containing flag values (i.e. if the tile has an item, warp, etc flag on it).&lt;br&gt;&lt;br&gt;&lt;b&gt;Priority tiles:&lt;/b&gt; Outputs a representation of the map with &apos;H&apos; = a high-priority tile, and &apos;L&apos; = a regular tile (low priority).&lt;br&gt;High priority tells the engine to draw tiles over the sprites (i.e. player character).&lt;/html&gt;"/>
                                    <Property name="text" type="java.lang.String" value=""/>
                                  </Properties>
                                </Component>
