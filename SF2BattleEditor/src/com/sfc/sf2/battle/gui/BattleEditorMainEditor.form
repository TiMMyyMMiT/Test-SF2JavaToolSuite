                                      <SubComponents>
                                        <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableAIRegions">
                                          <Properties>
                                            <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                              <Border info="null"/>
                                            </Property>
                                            <Property name="horizontalScrolling" type="boolean" value="true"/>
                                            <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;AI Regions indicate a an area that can influce specific enemy AI.&lt;br&gt;Edit the positions in the table directly - or select a row then click on the map to move the area around: Click near a point (corner) of the region to drag that point to the desired position.&lt;br&gt;&lt;br&gt;&lt;b&gt;Points:&lt;/b&gt;Regions are made up of a number of points: P1, P2, P3, P4. Or, as you will see in the data [x1,y1], [x2,y2], etc.&lt;br&gt;&lt;br&gt;&lt;b&gt;Type 3:&lt;/b&gt; Type 3 = a 3-point region (a triangle) made up of points [P1, P2, P3].&lt;br&gt;&lt;b&gt;Type 4:&lt;/b&gt; Type 4 = a 4-point region; or more accurately, 2 triangles made up of points [P1, P2, P4] &amp; [P2, P3, P4].&lt;/html&gt;"/>
                                            <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                              <ComponentRef name="aIRegionPropertiesTableModel"/>
                                            </Property>
                                            <Property name="selectionMode" type="int" value="0"/>
                                            <Property name="singleClickText" type="boolean" value="true"/>
                                            <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                            <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                              <Dimension value="[300, 100]"/>
                                            </Property>
                                          </Properties>
                                        </Component>
                                      </SubComponents>
