                                      </Layout>
                                      <SubComponents>
                                        <Component class="com.sfc.sf2.battle.tables.EnemyPropertiesTable" name="tableEnemies">
                                          <Properties>
                                            <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                                              <Border info="null"/>
                                            </Property>
                                            <Property name="horizontalScrolling" type="boolean" value="true"/>
                                            <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;When you select an enemy in the table, its data can then be edited in the controls below.&lt;br&gt;Like allies, selecting an enemy and then clicking on the map will move the enemy to the new position.&lt;br&gt;Enemy info:&lt;br&gt;&lt;b&gt;Enemy&lt;/b&gt;: The Id of the enemy. Determines which enemy.&lt;br&gt;&lt;b&gt;X/Y&lt;/b&gt;: The position of the enemy, relative to the top-left corner of the battle area.&lt;br&gt;&lt;b&gt;AI&lt;/b&gt;: Which AI logic the enemy will use.&lt;br&gt;&lt;b&gt;Spawn&lt;/b&gt;: AI Spawn rules:&lt;br&gt;    &lt;b&gt;Starting&lt;/b&gt;: The enemy is visible from the start of the battle.&lt;br&gt;    &lt;b&gt;Respawn&lt;/b&gt;: Enemy will respawn after being kiled, based on triggers.&lt;br&gt;    &lt;b&gt;Hidden&lt;/b&gt;: Enemy does not spawn into the battle until a trigger is activated. If no trigger is activated then enemy will never spawn.&lt;br&gt;&lt;b&gt;Item&lt;/b&gt;: The item the enemy holds and item flags. Item flags:&lt;br&gt;-    &lt;b&gt;EQUIPPED&lt;/b&gt;: Whether the enemy has this item equipped. May not do anything in the base game.&lt;br&gt;-    &lt;b&gt;USABLE_BY_AI&lt;/b&gt;: Flags that the item can be used by the AI. The base game is hard-coded so that this only works with Healing Water.&lt;br&gt;-    &lt;b&gt;UNUSED_ITEM_DROP&lt;/b&gt;: Flags the item to be dropped when enemy dies if it was not consumed (used) by the enemy.&lt;br&gt;-    &lt;b&gt;BROKEN&lt;/b&gt;: Flags the item as broken (cracked) and needs to be repaired.&lt;br&gt;&lt;b&gt;Move Order&lt;/b&gt;: Directs target to stay in place or move towards specific targets.&lt;br&gt;&lt;b&gt;Target (Move order)&lt;/b&gt;: The target of the move order. &lt;br&gt;&lt;b&gt;Trigger region 1/2&lt;/b&gt;: Move orders are activated when region triggers.&lt;br&gt;&lt;b&gt;Backup Move Order&lt;/b&gt;: Backup move order (TODO What does this do specifically).&lt;br&gt;&lt;b&gt;Target (backup)&lt;/b&gt;: Target for the backup move order.&lt;br&gt;&lt;b&gt;Unknown&lt;/b&gt;: It is unknown what this does. Valid values seem to be 0 or 6.&lt;/html&gt;"/>
                                            <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.ComponentChooserEditor">
                                              <ComponentRef name="enemyPropertiesTableModel"/>
                                            </Property>
                                            <Property name="selectionMode" type="int" value="0"/>
                                            <Property name="singleClickText" type="boolean" value="false"/>
                                            <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                                            <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                                              <Dimension value="[300, 100]"/>
                                            </Property>
                                          </Properties>
                                        </Component>
                                      </SubComponents>
                                    </Container>
