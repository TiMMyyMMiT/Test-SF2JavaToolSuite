                                          </Group>
                                        </DimensionLayout>
                                        <DimensionLayout dim="1">
                                          <Group type="103" groupAlignment="0" attributes="0">
                                              <Group type="102" alignment="1" attributes="0">
                                                  <EmptySpace max="-2" attributes="0"/>
                                                  <Component id="tableEnemies" pref="213" max="32767" attributes="0"/>
