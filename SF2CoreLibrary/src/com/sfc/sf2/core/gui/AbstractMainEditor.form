            <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton3">
              <Properties>
                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;If the .jar file detects that it is inside SF2DISASM then it will assume that the user wants to load data from this SF2DISASM directory.&lt;br&gt;Toggle this off and use the &apos;base folder&apos; and &apos;incbin folder&apos; to point to a custom directory.&lt;br&gt;&lt;b&gt;Most users do not need to edit this.&lt;/b&gt;&lt;/html&gt;"/>
                <Property name="text" type="java.lang.String" value=""/>
              </Properties>
            </Component>
            <Component class="com.sfc.sf2.core.gui.controls.DirectoryButton" name="directoryButtonBasePath">
              <Properties>
                <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;Base folder is where the .jar file is expected to be run from.&lt;br&gt;&lt;b&gt;Most users do not need to edit this path.&lt;/b&gt;&lt;/html&gt;"/>
                <Property name="labelText" type="java.lang.String" value="Base folder :"/>
                <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                  <Dimension value="[150, 25]"/>
                </Property>
                <Property name="preferredSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                  <Dimension value="[200, 25]"/>
                </Property>
              </Properties>
            </Component>
            <Component class="com.sfc.sf2.core.gui.controls.DirectoryButton" name="directoryButtonIncbinPath">
              <Properties>
                <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;Incbin is the root folder for the disassemby (usually SF2DISASM\u005cdisasm\u005c)&lt;br&gt;&lt;b&gt;Most users do not need to edit this path.&lt;/b&gt;&lt;/html&gt;" containsInvalidXMLChars="true"/>
