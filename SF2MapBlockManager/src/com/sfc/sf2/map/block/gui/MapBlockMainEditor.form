                                  <Properties>
                                    <Property name="messageText" type="java.lang.String" value="&lt;html&gt;Flip each tile in the selected block. Left click to toggle horizontal flip. Right click to toggle vertical flip. Middle click to clear any flipping.&lt;/html&gt;"/>
                                    <Property name="text" type="java.lang.String" value=""/>
                                  </Properties>
                                </Component>
                                <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton4">
                                  <Properties>
                                    <Property name="messageText" type="java.lang.String" value="&lt;html&gt;Set the priority flag for each tile. Left-click to set. Right-click to unset.&lt;br&gt;&apos;Priority&apos; means that the tile is drawn above the mapSprites (i.e. above characters).&lt;br&gt;Examples include roof tiles or the top tiles for a wall or table.&lt;/html&gt;"/>
                                    <Property name="text" type="java.lang.String" value=""/>
                                  </Properties>
                                </Component>
