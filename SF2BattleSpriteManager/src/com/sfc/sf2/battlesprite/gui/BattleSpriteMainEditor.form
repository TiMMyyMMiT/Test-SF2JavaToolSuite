                                    <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton5">
                                      <Properties>
                                        <Property name="messageText" type="java.lang.String" value="&lt;html&gt;Enter an image prefix or select an image, palette, or meta file. Examples of valid search patterns:&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01-frame&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01-frame-0&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01-frame-3.png&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01.meta&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01-palette&lt;br&gt;- .\u005callies\u005cexport\u005callybattlesprite01-palette-0.bin&lt;br&gt;&lt;br&gt;Supported image formats: PNG or GIF. Automatically detects valid image formats that match the file pattern.&lt;br&gt;&lt;br&gt;Color format should be 4BPP / 16 indexed colors. Images of 8BPP / 256 indexed colors will be converted to 4 BPP / 16 (some colors may be lost).&lt;br&gt;Colors will be convered to CRAM format (the color format used by the SEGA Genesis).&lt;br&gt;Color index 0 is treated as transparent.&lt;/html&gt;" containsInvalidXMLChars="true"/>
                                        <Property name="text" type="java.lang.String" value=""/>
                                      </Properties>
                                    </Component>
                                    <Component class="com.sfc.sf2.core.gui.controls.FileButton" name="fileButtonImportImage">
                                      <Properties>
                                        <Property name="fileFormatFilter" type="com.sfc.sf2.core.io.FileFormat" editor="org.netbeans.modules.form.editors.EnumEditor">
                                          <Value id="ALL_BATTLE_SPRITES_FORMAT"/>
                                        </Property>
                                        <Property name="filePath" type="java.lang.String" value=".\u005callies\u005cexport\u005callybattlesprite01" containsInvalidXMLChars="true"/>
                                        <Property name="infoMessage" type="java.lang.String" value=""/>
                                        <Property name="labelText" type="java.lang.String" value="Image prefix :"/>
                                        <Property name="name" type="java.lang.String" value="Import Images" noResource="true"/>
                                      </Properties>
                                    </Component>
