                                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;A normal attack can trigger a specific &lt;b&gt;Spell anim&lt;/b&gt; to trigger on the &lt;b&gt;Spell initial frame&lt;/b&gt;.&lt;br&gt;Values are linked to SF2Enums &quot;enum SpellAnimations&quot;.&lt;/html&gt;"/>
                                <Property name="text" type="java.lang.String" value=""/>
                              </Properties>
                            </Component>
                            <Component class="com.sfc.sf2.core.gui.controls.InfoButton" name="infoButton3">
                              <Properties>
                                <Property name="messageText" type="java.lang.String" value="&lt;html&gt;Whether or not to terminate spell animation when battle sprite anim finishes.&lt;/html&gt;"/>
                                <Property name="text" type="java.lang.String" value=""/>
                              </Properties>
                            </Component>
                          </SubComponents>
                        </Container>
                        <Component class="com.sfc.sf2.core.gui.controls.Table" name="tableFrames">
                          <Properties>
                            <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                              <Border info="org.netbeans.modules.form.compat2.border.TitledBorderInfo">
                                <TitledBorder title="Animation frames"/>
                              </Border>
                            </Property>
                            <Property name="infoMessage" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Frame:&lt;/b&gt; The frame number (cannot be edited).&lt;br&gt;&lt;b&gt;Battlesprite: &lt;/b&gt; The battlesprite to show during this frame.&lt;br&gt;&lt;b&gt;Duration:&lt;/b&gt; The speed of the animation. 60 = 1 second. Lower numbers animate faster.&lt;br&gt;&lt;b&gt;X/Y:&lt;/b&gt; The X and Y position offset when rendering the battle sprite.&lt;br&gt;&lt;b&gt;Weapon Index:&lt;/b&gt; The index of the weapon sprite frame to render.&lt;br&gt;&lt;b&gt;H/V Flip:&lt;/b&gt; Whether or not the weapon sprite is flipped Horizontally or Vertically.&lt;br&gt;&lt;b&gt;Behnd:&lt;/b&gt; Whether the weapon is rendered in front of or behind the batttle sprite.&lt;br&gt;&lt;b&gt;Weapon X/Y:&lt;/b&gt; The X and Y position offset when rendering the weapon.&lt;br&gt;&lt;br&gt;&lt;b&gt;Note:&lt;/b&gt; For frame 0; Battlesprite, Duration, X, and Y cannot be edited.&lt;/html&gt;"/>
                            <Property name="model" type="com.sfc.sf2.core.models.AbstractTableModel" editor="org.netbeans.modules.form.RADConnectionPropertyEditor">
                              <Connection component="battleSpriteAnimationFramesModel" type="bean"/>
                            </Property>
                            <Property name="selectionMode" type="int" value="0"/>
                            <Property name="singleClickText" type="boolean" value="false"/>
                            <Property name="spinnerNumberEditor" type="boolean" value="true"/>
                            <Property name="minimumSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                              <Dimension value="[260, 150]"/>
                            </Property>
                            <Property name="preferredSize" type="java.awt.Dimension" editor="org.netbeans.beaninfo.editors.DimensionEditor">
                              <Dimension value="[260, 200]"/>
                            </Property>
                          </Properties>
                        </Component>
                      </SubComponents>
                    </Container>
